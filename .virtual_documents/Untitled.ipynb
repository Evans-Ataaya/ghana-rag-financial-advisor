    if mask.sum() > 1:
        domain_embeds = corpus_embeddings[mask]
        within_sim = cosine_similarity(domain_embeds)
        # Get upper triangle (exclude self-similarity)
        triu_indices = np.triu_indices_from(within_sim, k=1)
        avg_sim = within_sim[triu_indices].mean()
        print(f"  {domain:<30} : {avg_sim:.4f} "
              f"(within-domain, {mask.sum()} chunks)")

print()
print("✅ complete — embeddings generated and visualised")
print("✅ building the vector store")





# --- 3.24 Build ChromaDB Vector Store ---
import chromadb

# Create persistent ChromaDB client
chroma_client = chromadb.PersistentClient(path="data/vectorstore/chromadb")

# Delete existing collection if it exists (for clean rebuilds)
try:
    chroma_client.delete_collection("ghana_financial_docs")
    print("Previous collection deleted.")
except:
    pass

# Create new collection
collection = chroma_client.create_collection(
    name="ghana_financial_docs",
    metadata={"description": "Ghana Financial RAG Advisor knowledge base"}
)

print("=" * 55)
print("BUILDING CHROMADB VECTOR STORE")
print("=" * 55)
print(f"Collection    : ghana_financial_docs")
print(f"Chunks to add : {len(final_chunks)}")
print()

# Prepare data for insertion
ids = []
documents = []
metadatas = []
embeddings_list = []

for i, chunk in enumerate(final_chunks):
    ids.append(chunk['chunk_id'])
    documents.append(chunk['text'])
    metadatas.append({
        "doc_id": chunk['doc_id'],
        "title": chunk['title'],
        "domain": chunk['domain'],
        "doc_type": chunk['doc_type'],
        "regulatory_body": chunk['regulatory_body'],
        "year": chunk['year'],
        "chunk_index": chunk['chunk_index'],
        "total_chunks": chunk['total_chunks'],
    })
    embeddings_list.append(corpus_embeddings[i].tolist())

# Add to collection in batches (ChromaDB has batch limits)
batch_size = 100
for start in range(0, len(ids), batch_size):
    end = min(start + batch_size, len(ids))
    collection.add(
        ids=ids[start:end],
        documents=documents[start:end],
        metadatas=metadatas[start:end],
        embeddings=embeddings_list[start:end],
    )
    print(f"  Added batch {start//batch_size + 1}: "
          f"chunks {start+1}–{end}")

print()
print("=" * 55)
print("VECTOR STORE BUILT SUCCESSFULLY")
print("=" * 55)
print(f"Total chunks stored : {collection.count()}")
print(f"Storage location    : data/vectorstore/chromadb/")
print(f"✅ ChromaDB collection ready for retrieval")



